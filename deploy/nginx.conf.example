# Reverse proxy Nginx untuk koperasi-mock-api.
# Salin ke: /etc/nginx/sites-available/koperasi-mock-api
# Aktifkan : ln -s /etc/nginx/sites-available/koperasi-mock-api /etc/nginx/sites-enabled/
# Uji+reload: nginx -t && systemctl reload nginx
#
# Ganti server_name dengan domain/subdomain Anda. Setelah ini jalankan Certbot
# untuk HTTPS (lihat DEPLOY.md). Certbot akan menambah blok listen 443 + sertifikat.

server {
    listen 80;
    listen [::]:80;
    server_name koperasi-mock.contoh.id;   # <-- GANTI dengan domain Anda

    # Batas body kecil (endpoint hanya GET + form simulasi mungil)
    client_max_body_size 1m;

    location / {
        proxy_pass         http://127.0.0.1:4000;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;

        # Teruskan header api-key/x-api-key/api_key apa adanya (default Nginx sudah).
        proxy_read_timeout 60s;
    }
}
