# Konfigurasi server. Catatan: aplikasi membaca process.env LANGSUNG (tanpa
# dotenv). Di VPS, set nilai ini lewat ecosystem.config.js (PM2) atau export
# di shell. File ini hanya referensi nilai.

# Port internal server Node (di-proxy oleh Nginx). Default 4000.
PORT=4000

# Validasi header api-key. Default true (produksi WAJIB key).
# Set false hanya untuk uji lokal tanpa key.
#   - Master data key (informasi/simpanan/pinjaman/simulasi): src/koperasi.js -> MASTER_DATA_API_KEY
#   - Key akuntansi (neraca lajur) per koperasi: src/koperasi.js -> KOPERASI[...].apiKey
REQUIRE_API_KEY=true
